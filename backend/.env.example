# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cfdi:cfdi_dev_pass@localhost:5432/cfdi_db

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create a project at https://console.cloud.google.com
# Enable: Gmail API
# Create OAuth 2.0 credentials (Web Application)
# Authorized redirect URIs (Google Cloud Console): http://localhost:3000/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/callback

# ── Object Storage (MinIO for dev) ────────────────────────────────────────────
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin123
STORAGE_REGION=us-east-1
STORAGE_BUCKET_RAW=raw-email-attachments
STORAGE_BUCKET_CFDI=normalized-cfdi
STORAGE_BUCKET_UPLOADS=zip-uploads
STORAGE_BUCKET_REPORTS=generated-reports
STORAGE_BUCKET_TEMP=temp-processing

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Token encryption ──────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here
